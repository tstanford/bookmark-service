meta {
  name: refresh token
  type: http
  seq: 16
}

post {
  url: {{serviceurl}}/api/refresh
  body: json
  auth: none
}

body:json {
  {{refreshToken}}
}

script:post-response {
  bru.setVar("authToken", res.getBody()["authToken"])
  bru.setVar("refreshToken", res.getBody()["refreshToken"])
}

settings {
  encodeUrl: true
  timeout: 0
}
